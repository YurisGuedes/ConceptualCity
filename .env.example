# Copy this file to .env.local and fill in real values for local development.
# In Vercel: Project Settings → Environment Variables — set the same keys there
# for Preview/Production (this file is just documentation, .env.local is not deployed).

# Required. Get one at https://resend.com/api-keys (sign up, then create a key).
RESEND_API_KEY=

# Optional. Sender shown on the careers-application notification email.
# Until a sending domain is verified in the Resend dashboard, you MUST use
# the sandbox address below — Resend also restricts sandbox sending to only
# the email address your Resend account was signed up with.
# Once a domain (e.g. conceptualcity.com) is verified in Resend, switch to
# something like "Conceptual City <careers@conceptualcity.com>".
RESEND_FROM_EMAIL="Conceptual City <onboarding@resend.dev>"

# Optional. Inbox that receives new job-application emails.
# Defaults to portugal@conceptualcity.com if unset (see lib/resend.ts).
RESEND_TO_EMAIL=portugal@conceptualcity.com

# REQUIRED IN PRODUCTION, one per domain this project serves. Feeds
# metadataBase (so canonical/hreflang/OG resolve correctly), sitemap.xml,
# robots.txt's Sitemap: line, and the JSON-LD structured data — see
# lib/site-config.ts and lib/request-context.ts (resolves the right one per
# request from the Host header). If any of these is missing on a production
# build, it silently falls back to a hardcoded default — which is exactly
# what happened to conceptualcity.pt once already (broke every SEO surface
# on the site for weeks before anyone noticed). Set these in Vercel's
# dashboard (Project Settings → Environment Variables) for every custom
# domain you attach to this project, not just once at initial setup.
# NEXT_PUBLIC_SITE_URL (no suffix) is the original PT variable name, kept as
# a fallback for NEXT_PUBLIC_SITE_URL_PT so it doesn't need renaming.
NEXT_PUBLIC_SITE_URL=https://www.conceptualcity.pt
NEXT_PUBLIC_SITE_URL_PT=https://www.conceptualcity.pt
NEXT_PUBLIC_SITE_URL_ES=https://www.conceptualcity.es
NEXT_PUBLIC_SITE_URL_COM=https://www.conceptualcity.com

# Optional, local dev only. This project serves 3 domains from one deployment
# via proxy.ts's Host-based rewrite — but localhost has no such Host header,
# so it defaults to "pt". Set to "es" to develop/test the Spanish site on
# localhost without touching DNS.
NEXT_PUBLIC_DEV_DOMAIN=pt

# Optional. Google Search Console ownership verification (the HTML meta tag
# variant), one per domain — see app/layout.tsx. NEXT_PUBLIC_GSC_VERIFICATION_ES
# has a hardcoded fallback (the code the Beedigital-managed property was
# already verified with, given before the domain transfer), so it works with
# no action needed unless the property gets re-verified under a new code.
# NEXT_PUBLIC_GSC_VERIFICATION_PT has no fallback — get the code from the
# conceptualcity.pt property in Search Console and set it here.
NEXT_PUBLIC_GSC_VERIFICATION_PT=
NEXT_PUBLIC_GSC_VERIFICATION_ES=

# Optional. Contact email for the ES JSON-LD entity (components/structured-data.tsx).
# Defaults to the pre-migration cityconceptual@gmail.com — a generic Gmail
# address is a weak trust signal for a B2B construction-labor business, set
# this once a real @conceptualcity.com (or similar) mailbox exists.
NEXT_PUBLIC_ES_CONTACT_EMAIL=

# Optional. Google Tag Manager container ID, one per domain (see app/layout.tsx).
# Unset = no GTM script loads at all (not an error, just inactive) — the old
# GTM-PKKCH2Q container from the Beedigital-managed site can't be reused (no
# account access), so these must be new containers created in your own
# Google account. GA4 is expected to be configured as a tag inside GTM, not
# as a separate component. Consent Mode v2 (lib/consent.ts) defaults
# everything to denied until the visitor accepts the cookie banner, so no
# events reach GTM/GA4 before that regardless of whether these are set.
NEXT_PUBLIC_GTM_ID_PT=
NEXT_PUBLIC_GTM_ID_ES=
